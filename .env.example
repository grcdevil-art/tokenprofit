# TokenSales Webhook Server - Environment Variables
# 复制此文件为 .env 并填入实际值

# ===========================================
# SendGrid 邮件服务配置
# ===========================================
# 获取 SendGrid API Key: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.your-sendgrid-api-key-here

# 发件人邮箱（建议使用域名邮箱，如 noreply@yourdomain.com）
FROM_EMAIL=noreply@tokensales.ai

# ===========================================
# 服务器配置
# ===========================================
# Webhook 服务端口（默认 3001）
WEBHOOK_PORT=3001

# API 代理服务端口（默认 3000）
PORT=3000

# ===========================================
# SiliconFlow API 配置（国产模型聚合平台）
# ===========================================
# 获取 API Key: https://siliconflow.com
SILICONFLOW_API_KEY=sk-your-siliconflow-key-here
SILICONFLOW_BASE_URL=https://api.siliconflow.cn

# ===========================================
# 其他可选配置
# ===========================================
# 新用户免费额度（美元）
FREE_CREDITS=10

# JWT Secret（用于未来的用户认证）
JWT_SECRET=your-random-secret-key-here
